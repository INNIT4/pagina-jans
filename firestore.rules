rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Rifas — público lee, admin escribe
    match /rifas/{rifaId} {
      allow read: if true;
      allow write: if request.auth != null;

      // Números — Admin SDK reserva/vende via /api/boletos/crear (bypasses rules).
      // Solo lectura pública para mostrar la grid de números.
      match /numeros/{numero} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Boletos — solo admin lee/escribe. Creación y consulta pública van por API server-side
    // (/api/boletos/crear y /api/boletos/consulta) con Admin SDK + rate limiting.
    match /boletos/{boletoId} {
      allow read, write: if request.auth != null;
    }

    // Códigos de descuento — solo admin gestiona.
    // Validación pública va por /api/discount/validate (Admin SDK + rate limiting).
    match /discount_codes/{codeId} {
      allow read, write: if request.auth != null;
    }

    // WhatsApp config — solo admin gestiona.
    // Rotación pública va por /api/whatsapp/rotate (Admin SDK).
    // Disponibilidad pública va por /api/whatsapp/active (solo devuelve booleano).
    match /whatsapp_config/{doc} {
      allow read, write: if request.auth != null;
    }

    // Cuentas bancarias — público lee (para mostrar las tarjetas de pago), admin gestiona
    match /bank_accounts/{accountId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Configuración de la app — admin gestiona, lectura pública para settings no sensibles
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Contenido del sitio (CMS) — público lee, admin edita
    match /site_content/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Comprobantes de pago — creación pública via /api/comprobantes/upload (Admin SDK).
    // Lectura pública solo del comprobante propio (el admin ve todos vía Admin SDK).
    match /comprobantes/{comprobanteId} {
      allow read: if true;
      allow create: if false;   // Solo via /api/comprobantes/upload (Admin SDK)
      allow update: if request.auth != null;
    }
  }
}
