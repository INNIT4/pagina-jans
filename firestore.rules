rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Verifica que el usuario autenticado tenga rol "admin" en usuarios_admin
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/usuarios_admin/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios_admin/$(request.auth.uid)).data.role == "admin";
    }

    // Verifica que el usuario autenticado tenga rol "admin" o "staff"
    function isStaff() {
      return request.auth != null
        && exists(/databases/$(database)/documents/usuarios_admin/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios_admin/$(request.auth.uid)).data.role in ["admin", "staff"];
    }

    // Rifas — público lee, solo admin escribe
    match /rifas/{rifaId} {
      allow read: if true;
      allow write: if isAdmin();

      // Números — público lee (grilla de números en tiempo real via onSnapshot).
      // Escritura exclusivamente via Admin SDK (/api/boletos/crear) que bypasea rules.
      match /numeros/{numero} {
        allow read: if true;
        allow write: if isStaff();
      }
    }

    // Boletos — solo admin/staff lee/escribe.
    // Creación y consulta pública van por API server-side con Admin SDK + rate limiting.
    match /boletos/{boletoId} {
      allow read, write: if isStaff();
    }

    // Códigos de descuento — solo admin gestiona.
    // Validación pública va por /api/discount/validate (Admin SDK + rate limiting).
    match /discount_codes/{codeId} {
      allow read, write: if isAdmin();
    }

    // WhatsApp config — solo admin gestiona.
    // Rotación pública va por /api/whatsapp/rotate (Admin SDK).
    match /whatsapp_config/{doc} {
      allow read, write: if isAdmin();
    }

    // Cuentas bancarias — público lee, solo admin escribe
    match /bank_accounts/{accountId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Configuración de la app — público lee settings no sensibles, solo admin escribe
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Contenido del sitio (CMS) — público lee, solo admin edita
    match /site_content/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Comprobantes de pago — público lee, creación solo via /api/comprobantes/upload (Admin SDK).
    // Update (aprobar/rechazar) solo admin/staff.
    match /comprobantes/{comprobanteId} {
      allow read: if true;
      allow create: if false;
      allow update: if isStaff();
    }

    // Roles admin — solo admins pueden gestionar roles. Nadie más puede leer ni escribir.
    match /usuarios_admin/{userId} {
      allow read, write: if isAdmin();
    }
  }
}
